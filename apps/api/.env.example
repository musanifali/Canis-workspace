# Workspace Service configuration.
#
# NOTE: the service reads process.env directly (no dotenv auto-load). Either
# export these before `npm run dev`, or use a loader like `dotenv -e .env --`.

# Postgres (matches packages/db docker-compose; port 5443).
WORKSPACE_DATABASE_URL=postgres://postgres:postgres@localhost:5443/workspace_engine
WORKSPACE_API_PORT=8270

# CORS allow-list for browser SDK callers (dev default is open).
# WORKSPACE_CORS_ORIGIN=https://your-app.example.com

# --- Self-signup (#91) ---
# Shared secret gating POST /v1/signup — signup fails closed (503) when unset,
# and requests must present it in x-provision-secret. Must be IDENTICAL to the
# dashboard's WORKSPACE_PROVISION_SECRET. Generate with: openssl rand -base64 32
WORKSPACE_PROVISION_SECRET=
