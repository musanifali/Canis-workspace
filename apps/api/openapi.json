        "parameters": [
          {
            "name": "x-provision-secret",
            "in": "header",
            "description": "Shared bootstrap secret proving the caller is the dashboard",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignupResponseDto"
                }
              }
            }
          }
        },
        "summary": "Provision a new tenant + owner user + admin key from a verified identity (idempotent on the owner's external id)",
        "tags": [
          "signup"
        ]
      }
    },
    "/v1/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [
          {
            "name": "x-provision-secret",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponseDto"
                }
              }
            }
          }
        },
        "summary": "Mint a session for an already-verified identity (BFF-only). 404 if the identity has never signed up.",
        "tags": [
          "auth"
        ]
      }
    },
    "/v1/auth/session": {
      "get": {
        "operationId": "AuthController_session",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "description": "Bearer <session token>",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionUserDto"
                }
              }
            }
          }
        },
        "summary": "Resolve the current session's user, or 401.",
        "tags": [
          "auth"
        ]
      }
    },
    "/v1/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "description": "Bearer <session token>",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": ""
          }
        },
        "summary": "Revoke the session server-side (idempotent).",
        "tags": [
          "auth"
        ]
      }
    },
    "/v1/auth/members": {
      "get": {
        "operationId": "AuthController_members",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "description": "Bearer <session token>",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MemberDto"
                  }
                }
              }
            }
          }
        },
        "summary": "List the tenant's members (owner only).",
        "tags": [
          "auth"
        ]
      }
    },
    "/v1/keys": {
      "get": {
        "operationId": "KeysController_list",
        "parameters": [
          {
            "name": "x-user-id",
            "in": "header",
            "description": "Acting end user",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "description": "Tenant API key (admin scope)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ApiKeyDto"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing/unknown API key or user"
          }
        },
        "summary": "List the tenant's API keys (metadata only — never the hash)",
        "tags": [
          "keys"
        ]
      },
      "post": {
        "operationId": "KeysController_mint",
        "parameters": [
          {
            "name": "x-user-id",
            "in": "header",
            "description": "Acting end user",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "description": "Tenant API key (admin scope)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MintedKeyDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing/unknown API key or user"
          }
        },
        "summary": "Mint a key — the raw value is returned exactly once",
        "tags": [
          "keys"
        ]
      }
    },
    "/v1/keys/{id}": {
      "delete": {
        "operationId": "KeysController_revoke",
        "parameters": [
          {
            "name": "x-user-id",
            "in": "header",
            "description": "Acting end user",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "description": "Tenant API key (admin scope)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "401": {
            "description": "Missing/unknown API key or user"
          },
          "404": {
            "description": "No live key with that id in this tenant"
          }
        },
        "summary": "Revoke a key (tenant-scoped; idempotent)",
        "tags": [
          "keys"
        ]
      }
    }
  },
  "info": {
    "title": "Workspace Service API",
    "description": "Durable, multi-tenant, versioned, audited persistence for Workspace Spec v1 documents. Versioned at /v1 from day one; see API_VERSIONING.md for the deprecation policy.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "WorkspaceSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "updatedAt": {
            "type": "number",
            "description": "Epoch millis of the last save."
          }
        },
        "required": [
          "id",
          "title",
          "updatedAt"
        ]
      },
      "WorkspaceRecordDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "updatedAt": {
            "type": "number",
            "description": "Epoch millis of the last save."
          },
          "spec": {
            "type": "object",
            "description": "The validated Workspace Spec v1 document."
          },
          "headVersion": {
            "type": "number"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "private",
              "team",
              "org"
            ]
          },
          "ownerUserId": {
            "type": "string"
          },
          "createdFromThreadId": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "title",
          "updatedAt",
          "spec",
          "headVersion",
          "visibility",
          "ownerUserId"
        ]
      },
      "WorkspaceVersionDto": {
        "type": "object",
        "properties": {
          "versionNumber": {
            "type": "number"
          },
          "prompt": {
            "type": "string",
            "nullable": true
          },
          "authorUserId": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "description": "ISO timestamp."
          },
          "specVersion": {
            "type": "number"
          },
          "spec": {
            "type": "object",
            "description": "The immutable spec snapshot this version stores."
          }
        },
        "required": [
          "versionNumber",
          "prompt",
          "authorUserId",
          "createdAt",
          "specVersion",
          "spec"
        ]
      },
      "WorkspaceShareDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "subjectType": {
            "type": "string",
            "enum": [
              "user",
              "team"
            ]
          },
          "subjectId": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "viewer",
              "editor"
            ]
          },
          "createdByUserId": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "subjectType",
          "subjectId",
          "role",
          "createdByUserId"
        ]
      },
      "GenerationAllowanceDto": {
        "type": "object",
        "properties": {
          "allowed": {
            "type": "boolean"
          },
          "reason": {
            "type": "string",
            "enum": [
              "budget_exceeded",
              "rate_limited"
            ]
          },
          "remainingThisMonth": {
            "type": "number",
            "nullable": true,
            "description": "Generations left this month; null = unlimited budget."
          },
          "remainingThisMinute": {
            "type": "number"
          },
          "plan": {
            "type": "string",
            "enum": [
              "free",
              "pro",
              "internal"
            ]
          },
          "monthlyCap": {
            "type": "number",
            "nullable": true,
            "description": "Effective monthly cap after plan + override; null = unlimited."
          },
          "usedThisMonth": {
            "type": "number"
          }
        },
        "required": [
          "allowed",
          "remainingThisMonth",
          "remainingThisMinute",
          "plan",
          "monthlyCap",
          "usedThisMonth"
        ]
      },
      "RecordGenerationResponseDto": {
        "type": "object",
        "properties": {
          "allowance": {
            "$ref": "#/components/schemas/GenerationAllowanceDto"
          }
        },
        "required": [
          "allowance"
        ]
      },
      "UsageMonthDto": {
        "type": "object",
        "properties": {
          "generations": {
            "type": "number"
          },
          "costCents": {
            "type": "number"
          }
        },
        "required": [
          "generations",
          "costCents"
        ]
      },
      "UsageWorkspaceRowDto": {
        "type": "object",
        "properties": {
          "workspaceId": {
            "type": "string",
            "nullable": true,
            "description": "Null for generations not attributed to a workspace."
          },
          "generations": {
            "type": "number"
          },
          "costCents": {
            "type": "number"
          }
        },
        "required": [
          "workspaceId",
          "generations",
          "costCents"
        ]
      },
      "UsageSummaryDto": {
        "type": "object",
        "properties": {
          "month": {
            "$ref": "#/components/schemas/UsageMonthDto"
          },
          "perWorkspace": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UsageWorkspaceRowDto"
            }
          },
          "readCostCents": {
            "type": "number",
            "description": "Always 0 — saved workspaces cost nothing to open (two-phase design); reads are never metered."
          }
        },
        "required": [
          "month",
          "perWorkspace",
          "readCostCents"
        ]
      },
      "DataContractDto": {
        "type": "object",
        "properties": {
          "entityName": {
            "type": "string"
          },
          "definition": {
            "type": "object",
            "description": "Serialized defineEntity surface (fields, kinds, capabilities) — revivable with core's reviveContract."
          },
          "createdAt": {
            "type": "string",
            "description": "ISO timestamp."
          },
          "updatedAt": {
            "type": "string",
            "description": "ISO timestamp."
          }
        },
        "required": [
          "entityName",
          "definition",
          "createdAt",
          "updatedAt"
        ]
      },
      "AuditEntryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Monotonic entry id (bigserial, serialized as a string)."
          },
          "workspaceId": {
            "type": "string",
            "nullable": true
          },
          "actorUserId": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "workspace.created",
              "workspace.updated",
              "workspace.rolled_back",
              "workspace.viewed",
              "workspace.deleted",
              "workspace.shared",
              "workspace.unshared",
              "workspace.visibility_changed",
              "workspace.duplicated",
              "workspace.spec_rejected",
              "contract.registered",
              "contract.updated",
              "contract.removed"
            ]
          },
          "detail": {
            "type": "object",
            "description": "Action-specific payload. For workspace.spec_rejected: the verdict plus the validator's structured errors/questions."
          },
          "createdAt": {
            "type": "string",
            "description": "ISO timestamp."
          }
        },
        "required": [
          "id",
          "actorUserId",
          "action",
          "detail",
          "createdAt"
        ]
      },
      "TelemetryAcceptedDto": {
        "type": "object",
        "properties": {
          "accepted": {
            "type": "number"
          }
        },
        "required": [
          "accepted"
        ]
      },
      "TelemetryEventCountDto": {
        "type": "object",
        "properties": {
          "event": {
            "type": "string"
          },
          "count": {
            "type": "number"
          }
        },
        "required": [
          "event",
          "count"
        ]
      },
      "TelemetryReasonCountDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string"
          },
          "count": {
            "type": "number"
          }
        },
        "required": [
          "reason",
          "count"
        ]
      },
      "TelemetrySummaryDto": {
        "type": "object",
        "properties": {
          "byEvent": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TelemetryEventCountDto"
            }
          },
          "degradedByReason": {
            "description": "block.degraded events by reason — the error-frequency view.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TelemetryReasonCountDto"
            }
          }
        },
        "required": [
          "byEvent",
          "degradedByReason"
        ]
      },
      "SignupResponseDto": {
        "type": "object",
        "properties": {
          "tenantId": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "orgName": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "apiKey": {
            "type": "string",
            "nullable": true,
            "description": "Raw admin API key — shown exactly once, only on first provision. null on an idempotent replay (the key already exists, hash-only)."
          },
          "created": {
            "type": "boolean",
            "description": "false = idempotent replay of an already-provisioned identity."
          }
        },
        "required": [
          "tenantId",
          "slug",
          "orgName",
          "userId",
          "apiKey",
          "created"
        ]
      },
      "SessionUserDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "tenantId": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "member"
            ]
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "userId",
          "tenantId",
          "role",
          "name",
          "email"
        ]
      },
      "LoginResponseDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Opaque session token for the cookie."
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "user": {
            "$ref": "#/components/schemas/SessionUserDto"
          }
        },
        "required": [
          "token",
          "expiresAt",
          "user"
        ]
      },
      "MemberDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "member"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "role",
          "createdAt"
        ]
      },
      "ApiKeyDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "enum": [
              "runtime",
              "admin"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastUsedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "revokedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "required": [
          "id",
          "name",
          "scope",
          "createdAt",
          "lastUsedAt",
          "revokedAt"
        ]
      },
      "MintedKeyDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "scope": {
            "type": "string",
            "enum": [
              "runtime",
              "admin"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastUsedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "revokedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "rawKey": {
            "type": "string",
            "description": "The raw key — shown exactly once, never retrievable again."
          }
        },
        "required": [
          "id",
          "name",
          "scope",
          "createdAt",
          "lastUsedAt",
          "revokedAt",
          "rawKey"
        ]
      }
    }
  }
}
