{
  "openapi": "3.0.0",
  "paths": {
    "/v1/workspaces": {
      "get": {
        "operationId": "WorkspacesController_list",
        "parameters": [
          {
            "name": "x-user-id",
            "in": "header",
            "description": "Acting end user within the tenant",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "description": "Tenant API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WorkspaceSummaryDto"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing/unknown API key or user"
          }
        },
        "summary": "List the tenant's workspaces (no spec payload)",
        "tags": [
          "workspaces"
        ]
      },
      "post": {
        "operationId": "WorkspacesController_create",
        "parameters": [
          {
            "name": "x-user-id",
            "in": "header",
            "description": "Acting end user within the tenant",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "description": "Tenant API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkspaceRecordDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing/unknown API key or user"
          },
          "422": {
            "description": "Spec is shape-valid but fails server-side contract/policy validation (the same validateSpec the renderer uses). Body carries a machine-readable `code` (spec_rejected | spec_needs_clarification) plus the validator's errors/questions. Nothing is persisted."
          }
        },
        "summary": "Save a new workspace (creates version 1)",
        "tags": [
          "workspaces"
        ]
      }
    },
    "/v1/workspaces/{id}": {
      "get": {
        "operationId": "WorkspacesController_get",
        "parameters": [
          {
            "name": "x-user-id",
            "in": "header",
