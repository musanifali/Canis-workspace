                "schema": {
                  "$ref": "#/components/schemas/WorkspaceRecordDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing/unknown API key or user"
          },
          "404": {
            "description": "Unknown or deleted workspace"
          }
        },
        "summary": "Fetch a workspace with its head-version spec",
        "tags": [
          "workspaces"
        ]
      },
      "put": {
        "operationId": "WorkspacesController_update",
        "parameters": [
          {
            "name": "x-user-id",
            "in": "header",
            "description": "Acting end user within the tenant",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "description": "Tenant API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkspaceRecordDto"
                }
              }
            }
          },
          "401": {
            "description": "Missing/unknown API key or user"
          },
          "404": {
            "description": "Unknown or deleted workspace"
          },
          "422": {
            "description": "Spec is shape-valid but fails server-side contract/policy validation. Body carries a machine-readable `code` plus the validator's errors/questions. No new version is persisted."
          }
        },
        "summary": "Save an edit (appends an immutable version)",
        "tags": [
          "workspaces"
        ]
      },
      "delete": {
        "operationId": "WorkspacesController_remove",
        "parameters": [
          {
            "name": "x-user-id",
            "in": "header",
            "description": "Acting end user within the tenant",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "description": "Tenant API key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "401": {
            "description": "Missing/unknown API key or user"
          },
          "404": {
            "description": "Unknown or deleted workspace"
          }
        },
        "summary": "Soft-delete a workspace (history is preserved)",
        "tags": [
          "workspaces"
        ]
      }
    },
    "/v1/workspaces/{id}/versions": {
