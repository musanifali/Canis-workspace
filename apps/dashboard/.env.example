# Server-side only — the API key never reaches the browser. The dashboard's
# client-side SDK talks to /api/canis, a GET-only proxy that injects the key.
# Provision the internal tenant + key with:
#   node scripts/seed-dashboard-tenant.mjs        (repo root)
WORKSPACE_API_URL=http://localhost:8270
WORKSPACE_API_KEY=
# Acting user pinned by the proxy for all dashboard reads.
WORKSPACE_DASHBOARD_USER=canis_ops

# --- Self-signup (#91): GitHub OAuth ---
# Register a GitHub OAuth app; its callback URL must be exactly
#   {DASHBOARD_BASE_URL}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DASHBOARD_BASE_URL=http://localhost:3002
# Shared secret proving signup calls come from this dashboard — must be
# IDENTICAL to the API service's WORKSPACE_PROVISION_SECRET. Generate with:
#   openssl rand -base64 32
WORKSPACE_PROVISION_SECRET=
