{
  "name": "@workspace-engine/core",
  "version": "0.1.0",
  "description": "Workspace Spec schemas, types, and pure helpers. Zero IO: no React, no DB, no fetch — zod is the only runtime dependency.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "fast-check": "^4.8.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
