{
  "name": "@workspace-engine/client",
  "version": "0.1.0",
  "description": "Typed client for the Workspace Service /v1 API, generated from its OpenAPI document. Ships the HTTP-backed WorkspaceStore the SDK consumes.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "generate": "openapi-typescript ../../apps/api/openapi.json -o src/generated/v1.d.ts"
  },
  "dependencies": {
    "@workspace-engine/core": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@workspace-engine/react": "0.1.0",
    "openapi-typescript": "^7.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
