nt-size, 13px); font-family: var(--we-font-family, inherit); justify-content: center; padding: var(--we-pad, 10px); gap: 2px;"><span style="color: var(--we-muted, #6b7280);">Exposure (USD)</span><strong style="font-size: 1.8em; color: var(--we-fg, #111827);">30333700</strong></div></div></div><div data-workspace-cell="" data-block-id="blk_hirisk" data-block-type="CasesTable" style="grid-column: 1 / span 12; grid-row: 3 / span 6; min-width: 0; min-height: 0;"><section style="display: flex; flex-direction: column; height: 100%; box-sizing: border-box; overflow: hidden; background: var(--we-bg, #ffffff); color: var(--we-fg, #111827); border: 1px solid var(--we-border, #e5e7eb); border-radius: var(--we-radius, 8px); font-size: var(--we-font-size, 13px); font-family: var(--we-font-family, inherit);" data-testid="ui-table"><header style="padding: var(--we-pad, 10px); border-bottom: 1px solid var(--we-border, #e5e7eb); font-weight: 600; flex: 0 0 auto;">High &amp; critical risk</header><div style="overflow: auto;"><table style="width: 100%; border-collapse: collapse; text-align: left;"><thead><tr><th scope="col" style="padding: 6px var(--we-pad, 10px); color: var(--we-muted, #6b7280); font-weight: 600; border-bottom: 1px solid var(--we-border, #e5e7eb); position: sticky; top: 0px; background: var(--we-bg, #ffffff);">id</th><th scope="col" style="padding: 6px var(--we-pad, 10px); color: var(--we-muted, #6b7280); font-weight: 600; border-bottom: 1px solid var(--we-border, #e5e7eb); position: sticky; top: 0px; background: var(--we-bg, #ffffff);">title</th><th scope="col" style="padding: 6px var(--we-pad, 10px); color: var(--we-muted, #6b7280); font-weight: 600; border-bottom: 1px solid var(--we-border, #e5e7eb); position: sticky; top: 0px; background: var(--we-bg, #ffffff);">customer</th><th scope="col" style="padding: 6px var(--we-pad, 10px); color: var(--we-muted, #6b7280); font-weight: 600; border-bottom: 1px solid var(--we-border, #e5e7eb); position: sticky; top: 0px; bac