exports[`demo workspaces render live against the case contract > renders "Portfolio by Category" to a stable, healthy tree 1`] = `"<div data-workspace-renderer="" data-workspace-title="Portfolio by Category"><div data-workspace-grid="" style="display: grid; grid-template-columns: repeat(12, minmax(0, 1fr)); grid-auto-rows: 96px; gap: 16px;"><div data-workspace-cell="" data-block-id="blk_stats" data-block-type="KpiCards" style="grid-column: 1 / span 12; grid-row: 1 / span 2; min-width: 0; min-height: 0;"><div data-testid="ui-kpis" style="display: grid; grid-auto-flow: column; gap: var(--we-gap, 8px); height: 100%;"><div style="display: flex; flex-direction: column; height: 100%; box-sizing: border-box; overflow: hidden; background: var(--we-bg, #ffffff); color: var(--we-fg, #111827); border: 1px solid var(--we-border, #e5e7eb); border-radius: var(--we-radius, 8px); font-size: var(--we-font-size, 13px); font-family: var(--we-font-family, inherit); justify-content: center; padding: var(--we-pad, 10px); gap: 2px;"><span style="color: var(--we-muted, #6b7280);">Cases</span><strong style="font-size: 1.8em; color: var(--we-fg, #111827);">240</strong></div><div style="display: flex; flex-direction: column; height: 100%; box-sizing: border-box; overflow: hidden; background: var(--we-bg, #ffffff); color: var(--we-fg, #111827); border: 1px solid var(--we-border, #e5e7eb); border-radius: var(--we-radius, 8px); font-size: var(--we-font-size, 13px); font-family: var(--we-font-family, inherit); justify-content: center; padding: var(--we-pad, 10px); gap: 2px;"><span style="color: var(--we-muted, #6b7280);">Peak risk score</span><strong style="font-size: 1.8em; color: var(--we-fg, #111827);">100</strong></div></div></div><div data-workspace-cell="" data-block-id="blk_board" data-block-type="GroupedBoard" style="grid-column: 1 / span 12; grid-row: 3 / span 6; min-width: 0; min-height: 0;"><section style="display: flex; flex-direction: column; height: 100%; box-sizing: border-box; ove