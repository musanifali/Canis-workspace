{
  "name": "workspace-engine",
  "private": true,
  "version": "0.0.0",
  "description": "Workspace Engine \u2014 natural language to safe, saved, native screens. Built on Tambo (consumed, never forked).",
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "packageManager": "npm@10.9.7",
  "scripts": {
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "build": "turbo run build",
    "verify:artifacts": "node scripts/smoke-artifacts.mjs",
    "size": "npm run size --workspace=@workspace-engine/react",
    "changeset": "changeset",
    "release:version": "changeset version",
    "pack:canary": "mkdir -p canary-dist && npm pack --workspace @workspace-engine/core --workspace @workspace-engine/react --workspace @workspace-engine/ui --workspace @workspace-engine/client --workspace @workspace-engine/cli --workspace @workspace-engine/devtools --pack-destination canary-dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "turbo": "^2.3.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "nextra": {
      "zod": "4.1.12"
    },
    "nextra-theme-docs": {
      "zod": "4.1.12"
    }
  }
}
