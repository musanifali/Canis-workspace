{
  "name": "workspace-engine",
  "private": true,
  "version": "0.0.0",
  "description": "Workspace Engine — natural language to safe, saved, native screens. Built on Tambo (consumed, never forked).",
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "npm@10.9.7",
  "scripts": {
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "build": "turbo run build",
    "verify:artifacts": "node scripts/smoke-artifacts.mjs",
    "size": "npm run size --workspace=@workspace-engine/react"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "turbo": "^2.3.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
